{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lark-deck-cyrus/deck-outline.schema.json",
  "title": "Deck Outline Plan",
  "type": "object",
  "required": ["version", "brief", "scene", "thesis", "outline", "asset_plan", "claim_discipline", "handoff"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": "1.0" },
    "brief": { "$ref": "#/$defs/brief" },
    "scene": { "$ref": "#/$defs/scene" },
    "thesis": { "$ref": "#/$defs/thesis" },
    "knowledge_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/knowledge_ref" }
    },
    "source_dossier_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/source_dossier_ref" }
    },
    "recipe_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/recipe_ref" }
    },
    "library_suggestions": {
      "type": "array",
      "items": { "$ref": "#/$defs/library_suggestion" }
    },
    "product_module_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/product_module_ref" }
    },
    "template_backlog_seed": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "outline": { "$ref": "#/$defs/outline" },
    "asset_plan": {
      "type": "array",
      "items": { "$ref": "#/$defs/asset_request" }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "claim_discipline": { "$ref": "#/$defs/claim_discipline" },
    "handoff": { "$ref": "#/$defs/handoff" }
  },
  "$defs": {
    "brief": {
      "type": "object",
      "required": ["title", "audience", "objective", "delivery_mode"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "audience": { "type": "string", "minLength": 1 },
        "requester_context": { "type": "string" },
        "objective": { "type": "string", "minLength": 1 },
        "success_metric": { "type": "string" },
        "delivery_mode": { "enum": ["local-agent", "feishu-bot", "unknown"] },
        "constraints": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "scene": {
      "type": "object",
      "required": ["industry", "business_moment", "core_tension", "confidence"],
      "additionalProperties": false,
      "properties": {
        "industry": { "type": "string", "minLength": 1 },
        "segment": { "type": "string" },
        "user_role": { "type": "string" },
        "business_moment": { "type": "string", "minLength": 1 },
        "core_tension": { "type": "string", "minLength": 1 },
        "confidence": { "enum": ["high", "medium", "low"] }
      }
    },
    "thesis": {
      "type": "object",
      "required": ["one_sentence", "pain_points", "solution_angle"],
      "additionalProperties": false,
      "properties": {
        "one_sentence": { "type": "string", "minLength": 1 },
        "pain_points": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/pain_point" }
        },
        "solution_angle": { "type": "string", "minLength": 1 },
        "differentiation": { "type": "string" }
      }
    },
    "pain_point": {
      "type": "object",
      "required": ["name", "why_now", "impact", "evidence_level"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "why_now": { "type": "string", "minLength": 1 },
        "impact": { "type": "string", "minLength": 1 },
        "evidence_level": { "enum": ["user-provided", "approved-story", "public-pattern", "hypothesis"] },
        "evidence_needed": { "type": "string" }
      }
    },
    "knowledge_ref": {
      "type": "object",
      "required": ["source", "used_for"],
      "additionalProperties": false,
      "properties": {
        "source": { "enum": ["feishu-base", "local-cache", "user-provided", "public"] },
        "provider": { "type": "string" },
        "table": { "type": "string" },
        "record_id": { "type": "string" },
        "doc_id": { "type": "string" },
        "query": { "type": "string" },
        "cache_path": { "type": "string" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "used_for": { "type": "string", "minLength": 1 }
      }
    },
    "source_dossier_ref": {
      "type": "object",
      "required": ["source", "used_for"],
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "runtime_source": { "type": "string" },
        "source_type": { "type": "string" },
        "page": { "type": ["integer", "string"] },
        "slide_key": { "type": "string" },
        "knowledge_id": { "type": "string" },
        "material_id": { "type": "string" },
        "path": { "type": "string" },
        "confidence": { "type": "string" },
        "used_for": { "type": "string", "minLength": 1 }
      }
    },
    "recipe_ref": {
      "type": "object",
      "required": ["id", "name", "used_for"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string" },
        "used_for": { "type": "string", "minLength": 1 },
        "narrative_arc": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "recommended_layouts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "library_suggestion": {
      "type": "object",
      "required": ["id", "title", "layout", "reason"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "layout": { "type": "string", "minLength": 1 },
        "variant": { "type": "string" },
        "thumbnail": { "type": "string" },
        "source": { "type": "object" },
        "reason": { "type": "string", "minLength": 1 },
        "insert_suggestion": { "type": "string" }
      }
    },
    "product_module_ref": {
      "type": "object",
      "required": ["id", "name", "narrative"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "narrative": { "type": "string", "minLength": 1 },
        "proof_suggestions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "recommended_layouts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "outline": {
      "type": "object",
      "required": ["arc", "slides"],
      "additionalProperties": false,
      "properties": {
        "arc": { "type": "string", "minLength": 1 },
        "slides": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/slide_plan" }
        }
      }
    },
    "slide_plan": {
      "type": "object",
      "required": [
        "key",
        "title",
        "role",
        "message",
        "key_idea",
        "emphasis",
        "talk_track",
        "proof_needed",
        "asset_need",
        "layout_candidate",
        "risk"
      ],
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "title": { "type": "string", "minLength": 1 },
        "role": {
          "enum": ["cover", "agenda", "context", "pain", "insight", "solution", "demo", "evidence", "case", "roadmap", "decision", "closing"]
        },
        "message": { "type": "string", "minLength": 1 },
        "key_idea": { "type": "string", "minLength": 1 },
        "emphasis": { "type": "string", "minLength": 1 },
        "talk_track": { "type": "string", "minLength": 1 },
        "proof_needed": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "asset_need": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "hero": {
          "type": "boolean",
          "description": "Whether this slide should be treated as a visual anchor / hero moment in the user-facing DESIGN_PLAN."
        },
        "density_budget": {
          "type": "string",
          "minLength": 1,
          "description": "Concrete content capacity for the slide, e.g. number of cards, rows, beats, proof blocks, and image/demo anchors."
        },
        "design_spec": { "$ref": "#/$defs/slide_design_spec" },
        "content_completion": {
          "type": "string",
          "minLength": 1,
          "description": "What the renderer or next planning pass must fill from source material, assumptions, or safe synthesis."
        },
        "fact_boundary": {
          "type": "string",
          "minLength": 1,
          "description": "Per-slide claim discipline: what can be stated, what is inferred, and what must not be invented."
        },
        "content_beats": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "layout_candidate": { "$ref": "#/$defs/layout_candidate" },
        "visual_intent": { "type": "string" },
        "motion_policy": {
          "enum": ["none", "reveal", "state-loop", "sequence-highlight", "demo-loop", "live-dashboard", "media-restart", "iframe-native"],
          "description": "Preferred DeckJSON motion policy. Use only when motion explains state, sequence, media restart, or native iframe interaction."
        },
        "prototype_kind": {
          "enum": ["report", "dashboard", "workflow-map", "mini-app", "phone-demo", "video-demo", "other"],
          "description": "For iframe/demo pages: what kind of work surface will be embedded."
        },
        "interaction": {
          "enum": ["static-scroll", "clickable", "guided-loop", "native-app", "video-only"],
          "description": "For iframe/demo pages: expected interaction contract."
        },
        "allow_remote": {
          "type": "boolean",
          "description": "For iframe/demo pages only. True when an https embed is intentionally remote and cannot be packaged locally."
        },
        "assets": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "risk_flags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/source_dossier_ref" }
        },
        "knowledge_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/source_dossier_ref" }
        },
        "material_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/source_dossier_ref" }
        },
        "risk": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "slide_design_spec": {
      "type": "object",
      "required": ["q0_role", "q1_memory", "q2_hierarchy", "q3_mood", "q4_tradeoff", "six_dimensions"],
      "additionalProperties": false,
      "properties": {
        "q0_role": {
          "type": "string",
          "minLength": 1,
          "description": "Q0: what role this page plays in the deck."
        },
        "q1_memory": {
          "type": "string",
          "minLength": 1,
          "description": "Q1: the one sentence the audience should remember."
        },
        "q2_hierarchy": {
          "type": "object",
          "required": ["a", "b", "c"],
          "additionalProperties": false,
          "properties": {
            "a": { "type": "string", "minLength": 1 },
            "b": { "type": "string", "minLength": 1 },
            "c": { "type": "string", "minLength": 1 },
            "d": { "type": "string", "minLength": 1 }
          },
          "description": "Q2: A/B/C/D information hierarchy for visual design."
        },
        "q3_mood": {
          "type": "string",
          "minLength": 1,
          "description": "Q3: desired visual mood and business tone."
        },
        "q4_tradeoff": {
          "type": "string",
          "minLength": 1,
          "description": "Q4: the main design/content tradeoff or thing to avoid."
        },
        "six_dimensions": {
          "type": "array",
          "minItems": 6,
          "items": { "type": "string", "minLength": 1 },
          "description": "Six concrete design dimensions such as density, hierarchy, proof anchor, rhythm, language, and delivery context."
        }
      }
    },
    "layout_candidate": {
      "type": "object",
      "required": ["layout"],
      "additionalProperties": false,
      "properties": {
        "layout": {
          "enum": ["cover", "agenda", "section", "content", "stats", "quote", "image-text", "table", "flow", "logo-wall", "arch-stack", "chart", "iframe-embed", "replica", "raw", "end"]
        },
        "variant": { "type": "string" },
        "rationale": { "type": "string" }
      }
    },
    "asset_request": {
      "type": "object",
      "required": ["id", "type", "need", "preferred_source"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "type": { "enum": ["image", "video", "icon", "logo", "avatar", "demo", "data", "other"] },
        "need": { "type": "string", "minLength": 1 },
        "query": { "type": "string" },
        "preferred_source": { "enum": ["feishu-base", "local-cache", "user-provided", "generated", "external", "none"] },
        "source_material_id": { "type": "string" },
        "resolved_path": { "type": "string" },
        "url": { "type": "string" },
        "permission_status": { "type": "string" },
        "provenance": { "type": "object" },
        "fallback": { "type": "string" },
        "required": { "type": "boolean", "default": false }
      }
    },
    "claim_discipline": {
      "type": "object",
      "required": ["unsupported_claims", "needs_user_confirmation"],
      "additionalProperties": false,
      "properties": {
        "unsupported_claims": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "needs_user_confirmation": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "handoff": {
      "type": "object",
      "required": ["target_skill", "deckjson_strategy"],
      "additionalProperties": false,
      "properties": {
        "target_skill": { "const": "deck-renderer" },
        "deckjson_strategy": { "enum": ["direct", "needs-user-confirmation", "needs-more-input"] },
        "notes": { "type": "string" }
      }
    }
  }
}
