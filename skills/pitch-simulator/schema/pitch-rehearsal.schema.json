{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lark-deck-cyrus/pitch-rehearsal.schema.json",
  "title": "Pitch Rehearsal Result",
  "type": "object",
  "required": [
    "version",
    "source",
    "meeting",
    "audience_panel",
    "deck_arc",
    "slide_reactions",
    "objection_map",
    "outcome_forecast",
    "revision_queue",
    "talk_track",
    "claim_discipline"
  ],
  "additionalProperties": false,
  "properties": {
    "version": { "const": "1.0" },
    "source": { "$ref": "#/$defs/source" },
    "meeting": { "$ref": "#/$defs/meeting" },
    "audience_panel": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/persona" }
    },
    "deck_arc": { "$ref": "#/$defs/deck_arc" },
    "slide_reactions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/slide_reaction" }
    },
    "objection_map": {
      "type": "array",
      "items": { "$ref": "#/$defs/objection" }
    },
    "outcome_forecast": { "$ref": "#/$defs/outcome_forecast" },
    "revision_queue": {
      "type": "array",
      "items": { "$ref": "#/$defs/revision" }
    },
    "talk_track": { "$ref": "#/$defs/talk_track" },
    "claim_discipline": { "$ref": "#/$defs/claim_discipline" }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": ["artifacts", "assumptions", "limitations"],
      "additionalProperties": false,
      "properties": {
        "artifacts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "assumptions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "limitations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "meeting": {
      "type": "object",
      "required": ["title", "audience", "objective", "success_next_step", "meeting_type"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "audience": { "type": "string", "minLength": 1 },
        "objective": { "type": "string", "minLength": 1 },
        "success_next_step": { "type": "string", "minLength": 1 },
        "meeting_type": {
          "enum": ["first-meeting", "solution-pitch", "poc-kickoff", "renewal", "investor-pitch", "internal-alignment", "review", "unknown"]
        },
        "known_context": { "type": "string" }
      }
    },
    "persona": {
      "type": "object",
      "required": ["id", "role", "agenda", "success_criteria", "likely_objections"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "role": { "type": "string", "minLength": 1 },
        "agenda": { "type": "string", "minLength": 1 },
        "success_criteria": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "likely_objections": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "deck_arc": {
      "type": "object",
      "required": ["summary", "strongest_moment", "weakest_moment", "narrative_risk", "scores"],
      "additionalProperties": false,
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "strongest_moment": { "type": "string", "minLength": 1 },
        "weakest_moment": { "type": "string", "minLength": 1 },
        "narrative_risk": { "type": "string", "minLength": 1 },
        "scores": { "$ref": "#/$defs/scores" }
      }
    },
    "scores": {
      "type": "object",
      "required": ["clarity", "urgency", "trust", "feasibility", "next_step_readiness"],
      "additionalProperties": false,
      "properties": {
        "clarity": { "type": "integer", "minimum": 0, "maximum": 100 },
        "urgency": { "type": "integer", "minimum": 0, "maximum": 100 },
        "trust": { "type": "integer", "minimum": 0, "maximum": 100 },
        "feasibility": { "type": "integer", "minimum": 0, "maximum": 100 },
        "next_step_readiness": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "slide_reaction": {
      "type": "object",
      "required": ["slide_key", "title", "reaction", "positive_signal", "friction", "likely_questions", "simulated_quote", "revision_hint"],
      "additionalProperties": false,
      "properties": {
        "slide_key": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "title": { "type": "string", "minLength": 1 },
        "reaction": { "type": "string", "minLength": 1 },
        "positive_signal": { "type": "string", "minLength": 1 },
        "friction": { "type": "string", "minLength": 1 },
        "likely_questions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "simulated_quote": { "type": "string", "minLength": 1 },
        "revision_hint": { "type": "string", "minLength": 1 }
      }
    },
    "objection": {
      "type": "object",
      "required": ["persona_id", "objection", "trigger_slide_keys", "best_response"],
      "additionalProperties": false,
      "properties": {
        "persona_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "objection": { "type": "string", "minLength": 1 },
        "trigger_slide_keys": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
        },
        "best_response": { "type": "string", "minLength": 1 }
      }
    },
    "outcome_forecast": {
      "type": "object",
      "required": ["primary_outcome", "confidence", "why", "conditions_to_improve"],
      "additionalProperties": false,
      "properties": {
        "primary_outcome": {
          "enum": ["advance-next-meeting", "request-more-material", "internal-review", "poc-approved", "defer", "reject", "unknown"]
        },
        "confidence": { "enum": ["high", "medium", "low"] },
        "why": { "type": "string", "minLength": 1 },
        "conditions_to_improve": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "revision": {
      "type": "object",
      "required": ["priority", "target", "issue", "change", "owner"],
      "additionalProperties": false,
      "properties": {
        "priority": { "enum": ["P0", "P1", "P2"] },
        "target": { "type": "string", "minLength": 1 },
        "issue": { "type": "string", "minLength": 1 },
        "change": { "type": "string", "minLength": 1 },
        "owner": { "enum": ["outline", "deck", "talk-track", "evidence", "asset"] }
      }
    },
    "talk_track": {
      "type": "object",
      "required": ["opening", "transition_notes", "closing_ask", "do_not_say"],
      "additionalProperties": false,
      "properties": {
        "opening": { "type": "string", "minLength": 1 },
        "transition_notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "closing_ask": { "type": "string", "minLength": 1 },
        "do_not_say": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "claim_discipline": {
      "type": "object",
      "required": ["simulated_not_observed", "needs_confirmation", "unsafe_claims_to_remove"],
      "additionalProperties": false,
      "properties": {
        "simulated_not_observed": { "type": "boolean" },
        "needs_confirmation": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "unsafe_claims_to_remove": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
