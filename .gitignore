# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# macOS / OS junk
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Build artifacts (regenerable from build.sh)
examples/sample-deck-inline.html
templates/slide-recipes.html

# Local user uploads / scratch (not part of the skill)
uploads/
thumbs/
thmx_unpacked/
screenshots/
*.thmx

# Per-invocation outputs from new-run.sh / render.py — regenerable, and
# often contain large user-provided scene images. Keep out of source.
runs/

# Skill distribution artifacts from package-skill.sh — regenerable,
# binary, dated. Don't commit.
lark-deck-cyrus-*.zip

# Node (if you ever add tooling)
node_modules/
package-lock.json

# Backup files
*.bak
*.orig
*~

# Preflight cache (per-machine cross-clone search results)
.deck-renderer-preflight-cache

# Base-backed local cache copies. Feishu Base is the source of truth.
.base-cache/

# Local candidate artifacts produced by eval/generator smoke tests.
library/knowledge/candidates/
library/presentation/candidates/
